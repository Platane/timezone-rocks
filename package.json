{
  "name": "timezone-rocks",
  "author": {
    "name": "platane"
  },
  "version": "0.0.1",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/bun": "1.3.14",
    "typescript": "6.0.3",
    "typescript-plugin-css-modules": "5.2.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "type": "tsc --noEmit",
    "lint": "npx @biomejs/biome format .",
    "test": "bun test packages/app packages/location-",
    "test:e2e": "( cd packages/e2e/ ; bunx playwright test --project chromium )",
    "build:locations": "( cd packages/location-index-builder ; bun run build )",
    "build:flags": "( cd packages/app ; bun run flags/buildSprite.ts )",
    "dev": "( cd packages/app-builder ; bunx vite )",
    "build:app": "( cd packages/app-builder ; bunx vite build )"
  }
}
