{
  "compilerOptions": {
    "jsx": "preserve",
    "module": "esnext",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "lib": ["dom", "esnext", "WebWorker"],
    "plugins": [{ "name": "typescript-plugin-css-modules" }],
    "types": ["bun"]
  },
  "exclude": ["node_modules"]
}
